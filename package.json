    "motion": "^12.35.0",
    "next": "^16.2.4",
    "next-themes": "^0.4.6",
    "posthog-js": "^1.372.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "shadcn": "^4.5.0",
    "sonner": "^2.0.7",
